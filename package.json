{
  "name": "dicom-viewer",
  "version": "1.0.0",
  "description": "DICOM viewer with Cornerstone3D — Axial, Sagittal, and Coronal views",
  "type": "module",
  "scripts": {
    "vite": "vite",
    "dev": "concurrently -k -n http,https -c cyan,magenta \"vite --config vite.config.ts\" \"vite --config vite.config.https.ts\"",
    "dev:http": "vite --config vite.config.ts",
    "dev:https": "vite --config vite.config.https.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "preview:host": "vite preview --host 0.0.0.0 --port 4173"
  },
  "dependencies": {
    "@cornerstonejs/core": "^2.0.0",
    "@cornerstonejs/dicom-image-loader": "^2.0.0",
    "@cornerstonejs/tools": "^2.0.0",
    "@iwer/devui": "^1.1.2",
    "@iwer/sem": "^0.2.5",
    "@iwsdk/core": "^0.2.2",
    "dicom-parser": "^1.8.21",
    "iwer": "^2.1.1",
    "pako": "^2.1.0",
    "three": "^0.177.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "concurrently": "^9.1.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.6"
  }
}
